{
  "plugins": {
    "load": {
      "paths": ["/absolute/path/to/unolock-agent"]
    },
    "entries": {
      "unolock-agent": {
        "enabled": true
      }
    }
  },
  "mcpServers": {
    "unolock-agent": {
      "type": "stdio",
      "command": "unolock-agent",
      "args": ["mcp"]
    }
  }
}
